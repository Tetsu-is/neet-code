#include <algorithm>
#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
  int singleNumber(vector<int> &nums) {
    sort(nums.begin(), nums.end());
    int l = 0;
    int r = nums.size() - 1;

    while (l < r) {
      int mid = (l + r) / 2;
      int fi = (mid % 2 == 0) ? mid : mid - 1;
      if (nums[fi] == nums[fi + 1]) {
        l = fi + 2;
      } else {
        r = fi;
      }
    }
    return nums[l];
  }

private:
};

int main(int argc, char *argv[]) {
  Solution *s = new Solution;
  vector<int> nums = {7, 6, 6, 7, 8};
  cout << s->singleNumber(nums) << endl;
  return 0;
}

